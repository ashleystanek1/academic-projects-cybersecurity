def factorial(n):

    if n == 0:
        return 1
    
    else:
        return n * factorial(n - 1)

def findPrime(n, i=2):

        #get number from user
        enteredNumber = int(input('Enter a number to see if it is prime: '))

        notPrime = False

        if n == 1:
            print(enteredNumber, 'is not prime.')

        if enteredNumber > 1:
            for i in range(2, enteredNumber):
                if (enteredNumber % i) == 0:
                    notPrime = True
                
        if notPrime:
            print(enteredNumber, 'is not prime.')

        else:
            print(enteredNumber, 'is prime.')

